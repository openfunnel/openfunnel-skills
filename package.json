  "keywords": [
    "openfunnel",
    "gtm",
    "sales-intelligence",
    "icp",
    "buying-signals"
  ],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "openfunnel": "file:openfunnel-0.1.0.tgz"
  }
}
